DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/blanca_luxury?schema=public"

NODE_ENV=development
PORT=3001

JWT_SECRET=
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

ALLOWED_ORIGINS=http://localhost:3000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
