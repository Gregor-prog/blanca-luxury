// Blanca Luxury — Prisma Schema (MySQL)
// Read-optimized: indexes on all FK columns, common filter fields,
// and compound indexes for the hottest query paths.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════

enum AdminRole {
  SUPER_ADMIN
  SHOWROOM_MANAGER
}

enum ProductOrigin {
  ITALY
  TURKEY
  LOCAL
  OTHER
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ProjectSector {
  RESIDENTIAL
  COMMERCIAL
  HOSPITALITY
  MEDICAL
  GOVERNMENT
}

enum ServiceInterest {
  FURNITURE
  DECOR
  INTERIOR_DESIGN
  DRAPERY
  CONSULTATION
}

enum InquirySource {
  WEBSITE
  WHATSAPP
  INSTAGRAM
  REFERRAL
  WALK_IN
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  QUOTED
  CONVERTED
  CLOSED
}

enum WhatsAppContext {
  INQUIRY_REPLY
  QUOTE_FOLLOW_UP
  CONSULTATION_BOOKED
  GENERAL
}

// ═══════════════════════════════════════════════════
// ADMINS
// ═══════════════════════════════════════════════════

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         AdminRole @default(SHOWROOM_MANAGER)
  showroomId   String?   @map("showroom_id") @db.VarChar(36)
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  showroom         Showroom?  @relation("AdminShowroom", fields: [showroomId], references: [id], onDelete: SetNull)
  createdShowrooms Showroom[] @relation("ShowroomCreatedBy")
  handledInquiries Inquiry[]  @relation("InquiryHandler")
  auditLogs        AuditLog[]
  posts            Post[]

  @@index([showroomId])
  @@index([role])

  @@map("admins")
}

// ═══════════════════════════════════════════════════
// SHOWROOMS
// ═══════════════════════════════════════════════════

model Showroom {
  id              String   @id @default(uuid())
  name            String
  city            String
  address         String   @db.VarChar(500)
  latitude        Float?
  longitude       Float?
  // Stored as JSON array of strings e.g. ["+234...","..."]
  phoneNumbers    Json?    @map("phone_numbers") @db.Json
  geotagMetadata  String?  @map("geotag_metadata") @db.Text
  email           String?
  whatsappNumber  String?  @map("whatsapp_number")
  instagramHandle String?  @map("instagram_handle")
  coverImageUrl      String?  @map("cover_image_url") @db.VarChar(500)
  coverCloudinaryId  String?  @map("cover_cloudinary_id")
  isActive        Boolean  @default(true) @map("is_active")
  createdById     String?  @map("created_by") @db.VarChar(36)
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  createdBy      Admin?          @relation("ShowroomCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  admins         Admin[]         @relation("AdminShowroom")
  products       Product[]
  collections    Collection[]
  inquiries      Inquiry[]
  lookbookImages LookbookImage[]
  showroomImages ShowroomImage[]

  @@index([city])
  @@index([isActive])
  @@index([createdById])

  @@map("showrooms")
}

model ShowroomImage {
  id            String  @id @default(uuid())
  showroomId    String  @map("showroom_id") @db.VarChar(36)
  url           String  @db.VarChar(500)
  cloudinaryId  String?
  caption       String?
  displayOrder  Int     @default(0) @map("display_order")

  // Relations
  showroom Showroom @relation(fields: [showroomId], references: [id], onDelete: Cascade)

  @@index([showroomId, displayOrder])

  @@map("showroom_images")
}

// ═══════════════════════════════════════════════════
// CATEGORIES
// ═══════════════════════════════════════════════════

model Category {
  id                String  @id @default(uuid())
  name              String
  slug              String  @unique
  description       String? @db.Text
  icon              String?
  imageUrl          String? @map("image_url") @db.VarChar(500)
  imageCloudinaryId String? @map("image_cloudinary_id")
  displayOrder      Int     @default(0) @map("display_order")
  isActive          Boolean @default(true) @map("is_active")

  // Relations
  products Product[]

  @@index([isActive, displayOrder])

  @@map("categories")
}

// ═══════════════════════════════════════════════════
// PRODUCTS
// ═══════════════════════════════════════════════════

model Product {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  description     String?       @db.Text
  style           String?
  type            String?
  origin          ProductOrigin @default(OTHER)
  materials       String?       @db.Text
  dimensions      String?
  leadTime        String?       @map("lead_time")
  price           Decimal?      @db.Decimal(12, 2)
  priceOnRequest  Boolean       @default(false) @map("price_on_request")
  categoryId      String?       @map("category_id") @db.VarChar(36)
  showroomId      String?       @map("showroom_id") @db.VarChar(36)
  isFeatured      Boolean       @default(false) @map("is_featured")
  isActive        Boolean       @default(true) @map("is_active")
  metaTitle       String?       @map("meta_title")
  metaDescription String?       @map("meta_description") @db.VarChar(500)
  createdById     String?       @map("created_by") @db.VarChar(36)
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  showroom           Showroom?           @relation(fields: [showroomId], references: [id], onDelete: SetNull)
  media              ProductMedia[]
  tags               ProductTag[]
  collectionProducts CollectionProduct[]
  inquiries          Inquiry[]
  lookbookImages     LookbookImage[]

  @@index([isActive, isFeatured])
  @@index([isActive, categoryId])
  @@index([isActive, showroomId])
  @@index([categoryId, showroomId, isActive])
  @@index([origin])
  @@index([createdAt(sort: Desc)])
  @@index([createdById])

  @@map("products")
}

// ═══════════════════════════════════════════════════
// PRODUCT MEDIA
// ═══════════════════════════════════════════════════

model ProductMedia {
  id           String    @id @default(uuid())
  productId    String    @map("product_id") @db.VarChar(36)
  url          String    @db.VarChar(500)
  cloudinaryId String?
  mediaType    MediaType @default(IMAGE) @map("media_type")
  displayOrder Int       @default(0) @map("display_order")
  altText      String?   @map("alt_text")
  isPrimary    Boolean   @default(false) @map("is_primary")

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isPrimary])
  @@index([productId, displayOrder])

  @@map("product_media")
}

// ═══════════════════════════════════════════════════
// TAGS (many-to-many with Products)
// ═══════════════════════════════════════════════════

model Tag {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  // Relations
  products ProductTag[]

  @@map("tags")
}

model ProductTag {
  productId String @map("product_id") @db.VarChar(36)
  tagId     String @map("tag_id") @db.VarChar(36)

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])

  @@map("product_tags")
}

// ═══════════════════════════════════════════════════
// COLLECTIONS
// ═══════════════════════════════════════════════════

model Collection {
  id            String  @id @default(uuid())
  name          String
  slug          String  @unique
  description   String? @db.Text
  badgeText     String? @map("badge_text")
  year          Int?
  showroomId    String? @map("showroom_id") @db.VarChar(36)
  coverImageUrl String? @map("cover_image_url") @db.VarChar(500)
  isFeatured    Boolean @default(false) @map("is_featured")
  isActive      Boolean @default(true) @map("is_active")
  displayOrder  Int     @default(0) @map("display_order")

  // Relations
  showroom Showroom?           @relation(fields: [showroomId], references: [id], onDelete: SetNull)
  products CollectionProduct[]

  @@index([isActive, isFeatured])
  @@index([isActive, showroomId])
  @@index([isActive, displayOrder])

  @@map("collections")
}

model CollectionProduct {
  collectionId String @map("collection_id") @db.VarChar(36)
  productId    String @map("product_id") @db.VarChar(36)
  displayOrder Int    @default(0) @map("display_order")

  // Relations
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@index([collectionId, displayOrder])
  @@index([productId])

  @@map("collection_products")
}

// ═══════════════════════════════════════════════════
// PROJECTS (Portfolio)
// ═══════════════════════════════════════════════════

model Project {
  id                String        @id @default(uuid())
  title             String
  slug              String        @unique
  description       String?       @db.Text
  sector            ProjectSector @default(RESIDENTIAL)
  location          String?
  year              Int?
  clientName        String?       @map("client_name")
  coverImageUrl     String?       @map("cover_image_url") @db.VarChar(500)
  coverCloudinaryId String?       @map("cover_cloudinary_id")
  isFeatured        Boolean       @default(false) @map("is_featured")
  isActive          Boolean       @default(true) @map("is_active")
  createdById       String?       @map("created_by") @db.VarChar(36)
  createdAt         DateTime      @default(now()) @map("created_at")

  // Relations
  media        ProjectMedia[]
  testimonials Testimonial[]

  @@index([isActive, isFeatured])
  @@index([isActive, sector])
  @@index([isActive, year(sort: Desc)])
  @@index([createdAt(sort: Desc)])

  @@map("projects")
}

model ProjectMedia {
  id           String    @id @default(uuid())
  projectId    String    @map("project_id") @db.VarChar(36)
  url          String    @db.VarChar(500)
  cloudinaryId String?
  mediaType    MediaType @default(IMAGE) @map("media_type")
  caption      String?
  displayOrder Int       @default(0) @map("display_order")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, displayOrder])

  @@map("project_media")
}

// ═══════════════════════════════════════════════════
// INQUIRIES
// ═══════════════════════════════════════════════════

model Inquiry {
  id              String           @id @default(uuid())
  fullName        String           @map("full_name")
  phone           String?
  email           String?
  message         String?          @db.Text
  serviceInterest ServiceInterest? @map("service_interest")
  showroomId      String?          @map("showroom_id") @db.VarChar(36)
  productId       String?          @map("product_id") @db.VarChar(36)
  source          InquirySource    @default(WEBSITE)
  status          InquiryStatus    @default(NEW)
  assignedTo      String?          @map("assigned_to") @db.VarChar(36)
  createdAt       DateTime         @default(now()) @map("created_at")

  // Relations
  showroom      Showroom? @relation(fields: [showroomId], references: [id], onDelete: SetNull)
  product       Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  assignedAdmin Admin?    @relation("InquiryHandler", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([showroomId, status])
  @@index([assignedTo, status])
  @@index([productId])
  @@index([createdAt(sort: Desc)])

  @@map("inquiries")
}

// ═══════════════════════════════════════════════════
// LOOKBOOK IMAGES
// ═══════════════════════════════════════════════════

model LookbookImage {
  id           String  @id @default(uuid())
  imageUrl     String  @map("image_url") @db.VarChar(500)
  caption      String?
  showroomId   String? @map("showroom_id") @db.VarChar(36)
  productId    String? @map("product_id") @db.VarChar(36)
  displayOrder Int     @default(0) @map("display_order")
  isActive     Boolean @default(true) @map("is_active")

  // Relations
  showroom Showroom? @relation(fields: [showroomId], references: [id], onDelete: SetNull)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([isActive, showroomId, displayOrder])
  @@index([isActive, displayOrder])
  @@index([productId])

  @@map("lookbook_images")
}

// ═══════════════════════════════════════════════════
// POSTS (Blog / News)
// ═══════════════════════════════════════════════════

model Post {
  id            String    @id @default(uuid())
  title         String
  slug          String    @unique
  content       String    @db.LongText
  coverImageUrl String?   @map("cover_image_url") @db.VarChar(500)
  category      String?
  authorId      String?   @map("author_id") @db.VarChar(36)
  isPublished   Boolean   @default(false) @map("is_published")
  publishedAt   DateTime? @map("published_at")

  // Relations
  author Admin? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([isPublished, publishedAt(sort: Desc)])
  @@index([isPublished, category])
  @@index([authorId])

  @@map("posts")
}

// ═══════════════════════════════════════════════════
// TESTIMONIALS
// ═══════════════════════════════════════════════════

model Testimonial {
  id          String   @id @default(uuid())
  clientName  String   @map("client_name")
  clientTitle String?  @map("client_title")
  content     String   @db.Text
  rating      Int      @default(5)
  projectId   String?  @map("project_id") @db.VarChar(36)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([isActive, rating(sort: Desc)])
  @@index([projectId, isActive])

  @@map("testimonials")
}

// ═══════════════════════════════════════════════════
// AUDIT LOGS
// ═══════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id") @db.VarChar(36)
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.VarChar(36)
  changes    Json?    @db.Json
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])

  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════
// WHATSAPP TEMPLATES
// ═══════════════════════════════════════════════════

model WhatsAppTemplate {
  id              String          @id @default(uuid())
  name            String          @unique
  messageTemplate String          @map("message_template") @db.Text
  context         WhatsAppContext @default(GENERAL)
  isActive        Boolean         @default(true) @map("is_active")

  @@index([isActive, context])

  @@map("whatsapp_templates")
}
